# Скопируйте в .env и задайте свои значения:
#   cp .env.example .env
#
# Файл .env не попадает в git.

# Postgres (данные такси; insert_data_2025.py подключается с хоста)
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=taxi_db
POSTGRES_ARCHIVE_DB=taxi_archive
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ClickHouse (используется Airflow DAG-ами и Superset)
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=change_me
CLICKHOUSE_HTTP_PORT=8123

# Superset
SUPERSET_SECRET_KEY=change_me_to_random_string
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=change_me
SUPERSET_ADMIN_EMAIL=admin@example.com
